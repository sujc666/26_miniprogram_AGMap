<view class="page-shell discover-page">
  <view class="top card">
    <text class="section-title">全部奇遇</text>
    <text class="section-subtitle">{{currentMode === 'special' ? '专题中' : '通用版骨架'}} · {{topicTitle}}</text>

    <view class="mode-switch-line">
      <button class="mode-switch-btn" bindtap="onToggleMode">
        {{currentMode === 'special' ? '切到通用版' : '切到专题版'}}
      </button>
    </view>

    <view class="search-wrap">
      <input
        class="search-input"
        type="text"
        value="{{keyword}}"
        placeholder="搜索活动名或社团名"
        bindinput="onKeywordInput"
      />
      <text wx:if="{{keyword}}" class="search-clear" bindtap="onClearKeyword">清空</text>
    </view>
  </view>

  <scroll-view class="category-scroll" scroll-x enable-flex show-scrollbar="false">
    <view class="category-row">
      <view
        wx:for="{{categoryOptions}}"
        wx:key="*this"
        class="category-pill {{selectedCategory === item ? 'active' : ''}}"
        data-category="{{item}}"
        bindtap="onCategoryTap"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <view class="result-tip">共找到 {{filteredEvents.length}} 条活动</view>

  <view wx:if="{{filteredEvents.length === 0}}" class="empty-state">
    <!-- 可替换为微仔空状态插画，建议尺寸 260x260 -->
    <image
      wx:if="{{showEmptyImage}}"
      class="empty-image"
      src="{{appConfig.emptyStateImage}}"
      mode="aspectFit"
      binderror="onEmptyImageError"
    />
    <view wx:else class="empty-avatar"></view>
    <text class="empty-title">暂时没有匹配结果</text>
    <text class="empty-copy">换个关键词，或切换分类再看看吧。</text>
  </view>

  <view
    wx:for="{{filteredEvents}}"
    wx:key="id"
    class="event-card card"
    data-event-id="{{item.id}}"
    bindtap="onOpenDetail"
  >
    <view class="event-top">
      <text class="event-title">{{item.title}}</text>
      <text class="event-category">{{item.category}}</text>
    </view>
    <text class="event-club">{{item.club}}</text>
    <text class="event-meta">时间：{{item.time}}</text>
    <text class="event-meta">地点：{{item.locationName}}</text>
    <text class="event-tags">{{item.tagLine}}</text>
    <text class="event-desc line-clamp-2">{{item.shortDesc}}</text>
  </view>
</view>
