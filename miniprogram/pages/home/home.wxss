.home-page {
  background:
    radial-gradient(circle at 95% 3%, rgba(169, 221, 247, 0.25), transparent 28%),
    radial-gradient(circle at 5% 45%, rgba(191, 234, 124, 0.28), transparent 32%),
    linear-gradient(180deg, #FFFBEF 0%, #F5FAEA 100%);
}

.home-page.mode-special {
  background:
    radial-gradient(circle at 88% 2%, rgba(246, 167, 200, 0.22), transparent 26%),
    radial-gradient(circle at 6% 34%, rgba(247, 216, 94, 0.22), transparent 30%),
    linear-gradient(180deg, #FFFBEF 0%, #F8F2E8 100%);
}

.home-page.mode-general {
  background:
    radial-gradient(circle at 90% 10%, rgba(169, 221, 247, 0.24), transparent 26%),
    radial-gradient(circle at 8% 52%, rgba(191, 234, 124, 0.24), transparent 30%),
    linear-gradient(180deg, #FFFBEF 0%, #EEF7EE 100%);
}

.banner {
  position: relative;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.home-page.mode-special .banner {
  background:
    radial-gradient(circle at 14% 14%, rgba(255, 250, 222, 0.88), transparent 40%),
    linear-gradient(135deg, #FFE7BE 0%, #FFD9D8 38%, #FFF1C6 100%);
  border: 2rpx solid rgba(214, 127, 74, 0.22);
}

.banner-title {
  display: block;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #5f4a33;
}

.banner-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8C7B68;
}

.home-page.mode-special .banner-subtitle {
  color: #99663C;
}

.banner-tags {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
}

.mode-switch-line {
  margin-top: 12rpx;
  display: flex;
}

.mode-switch-btn {
  margin: 0;
  min-height: auto;
  line-height: 1.2;
  border: none;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  background: #D6EEFC;
  color: #5f4a33;
  font-size: 20rpx;
  white-space: nowrap;
}

.home-page.mode-special .mode-switch-btn {
  background: linear-gradient(135deg, #FFE7A9 0%, #FFD7BE 100%);
  color: #754528;
}

.mode-switch-btn::after {
  border: none;
}

.banner-mascot {
  flex-shrink: 0;
  width: 148rpx;
  height: 148rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #DDF3B2 0%, #BFEA7C 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.festival-halo {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.festival-halo.halo-a {
  width: 160rpx;
  height: 160rpx;
  right: -38rpx;
  top: -46rpx;
  background: radial-gradient(circle, rgba(255, 245, 198, 0.62) 0%, rgba(255, 245, 198, 0) 70%);
}

.festival-halo.halo-b {
  width: 120rpx;
  height: 120rpx;
  left: -24rpx;
  bottom: -32rpx;
  background: radial-gradient(circle, rgba(255, 221, 197, 0.48) 0%, rgba(255, 221, 197, 0) 72%);
}

.mascot-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
}

.mascot-fallback {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 251, 239, 0.8);
  color: #6B563C;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.section-head {
  margin: 12rpx 2rpx 14rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tab-scroll {
  width: 100%;
  margin-bottom: 16rpx;
}

.tab-row {
  display: inline-flex;
  gap: 14rpx;
  padding-bottom: 4rpx;
}

.area-tab,
.point-tab {
  border-radius: 22rpx;
  padding: 16rpx 20rpx;
  min-width: 190rpx;
  background: #fff;
  box-shadow: 0 8rpx 18rpx rgba(107, 86, 60, 0.08);
}

.area-tab.active {
  background: linear-gradient(180deg, #DDF3B2 0%, #BFEA7C 100%);
}

.home-page.mode-special .area-tab.active {
  background: linear-gradient(135deg, #FFE5A4 0%, #FFD2C4 100%);
  box-shadow: 0 10rpx 20rpx rgba(184, 114, 70, 0.2);
}

.tab-name,
.point-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #5f4a33;
}

.tab-desc,
.point-mark {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8C7B68;
}

.point-tab.active {
  border: 2rpx solid #8CCB5E;
}

.home-page.mode-special .point-tab.active {
  border-color: #DE8B55;
  background: #FFF1DC;
}

.home-page.mode-general .point-tab.active {
  border-color: #7DC7EA;
  background: #EAF6FF;
}

.point-tab.lit {
  background: #F2FFE3;
}

.map-card {
  padding: 24rpx;
  margin-top: 8rpx;
}

.map-area-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.map-canvas {
  position: relative;
  height: 420rpx;
  border-radius: 26rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #F0FCE4 0%, #EBF8DE 100%);
}

.home-page.mode-special .map-canvas {
  background: linear-gradient(160deg, #FFF6D3 0%, #FFEAF2 50%, #EAF8D9 100%);
}

.home-page.mode-general .map-canvas {
  background: linear-gradient(180deg, #ECF8FF 0%, #EAF8EE 100%);
}

.zone {
  position: absolute;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: rgba(107, 86, 60, 0.86);
  z-index: 1;
}

.home-page.mode-special .zone {
  box-shadow: inset 0 0 0 2rpx rgba(255, 251, 239, 0.45);
}

.home-page.mode-general .zone {
  border-radius: 20rpx;
}

.zone-center {
  left: 28%;
  top: 24%;
  width: 42%;
  height: 44%;
  background: rgba(191, 234, 124, 0.42);
}

.zone-west {
  left: 4%;
  top: 18%;
  width: 28%;
  height: 58%;
  background: rgba(169, 221, 247, 0.36);
}

.zone-east {
  right: 4%;
  top: 16%;
  width: 30%;
  height: 62%;
  background: rgba(247, 216, 94, 0.34);
}

.zone-on {
  box-shadow: inset 0 0 0 4rpx rgba(107, 86, 60, 0.2);
}

.map-point {
  position: absolute;
  transform: translate(-50%, -50%);
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  border-radius: 999rpx;
  padding: 8rpx 12rpx;
  background: rgba(255, 251, 239, 0.96);
  box-shadow: 0 8rpx 14rpx rgba(107, 86, 60, 0.12);
  z-index: 3;
}

.home-page.mode-general .map-point {
  background: rgba(255, 255, 255, 0.98);
}

.map-point.dim {
  opacity: 0.5;
}

.map-point.active {
  background: #DDF3B2;
  box-shadow: 0 10rpx 16rpx rgba(140, 203, 94, 0.38);
}

.home-page.mode-general .map-point.active {
  background: #D8F0FF;
  box-shadow: 0 10rpx 16rpx rgba(125, 199, 234, 0.38);
}

.map-point.lit {
  border: 2rpx solid #8CCB5E;
}

.point-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6B563C;
}

.point-label {
  font-size: 20rpx;
  color: #6B563C;
  font-weight: 600;
}

.map-caption {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #8C7B68;
}

.action-row {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.action-btn {
  width: 100%;
}

.event-head {
  margin-top: 20rpx;
}

.event-card {
  margin-top: 14rpx;
  padding: 22rpx;
}

.home-page.mode-special .event-card {
  border: 2rpx solid rgba(222, 139, 85, 0.26);
  box-shadow: 0 14rpx 28rpx rgba(184, 114, 70, 0.14);
}

.event-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.event-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5c462f;
}

.event-category {
  flex-shrink: 0;
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #5f4b34;
  background: #DDF3B2;
}

.home-page.mode-special .event-category {
  background: linear-gradient(135deg, #FFE3A0 0%, #FFD2C4 100%);
  color: #7A4A2C;
}

.event-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8C7B68;
}

.event-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6B563C;
  line-height: 1.45;
}

.event-action-row {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
}

.event-light-btn {
  margin: 0;
  flex: 1;
  min-height: auto;
  line-height: 1.2;
  border: none;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  font-size: 20rpx;
  color: #5f4a33;
  background: #DDF3B2;
}

.event-light-btn.lit {
  background: #BFEA7C;
  color: #4a6f2c;
}

.home-page.mode-special .event-light-btn {
  background: #FFE9BA;
  color: #7A4A2C;
}

.home-page.mode-special .event-light-btn.lit {
  background: #FFD9B7;
  color: #7A4024;
}

.event-light-btn::after {
  border: none;
}

.event-fav-btn {
  margin: 0;
  flex: 1;
  min-height: auto;
  line-height: 1.2;
  border: none;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  font-size: 20rpx;
  color: #5f4a33;
  background: #FFE9B8;
}

.event-fav-btn.fav {
  background: #FFD1E2;
  color: #7a3f5f;
}

.home-page.mode-special .event-fav-btn {
  background: #FFEAD8;
  color: #7A4A2C;
}

.home-page.mode-special .event-fav-btn.fav {
  background: #FFCDB8;
  color: #7B3A22;
}

.event-fav-btn::after {
  border: none;
}

.bottom-action-row {
  margin-top: 22rpx;
  margin-bottom: 12rpx;
}

.bottom-discover-btn {
  width: 100%;
  margin: 0;
  min-height: auto;
  line-height: 1.2;
  border: none;
  border-radius: 999rpx;
  padding: 18rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #5f4a33;
  background: #E6F5CD;
}

.home-page.mode-special .bottom-discover-btn {
  background: linear-gradient(135deg, #FFE2A5 0%, #FFD4C4 100%);
  color: #7A4A2C;
  box-shadow: 0 10rpx 20rpx rgba(184, 114, 70, 0.2);
}

.bottom-discover-btn::after {
  border: none;
}