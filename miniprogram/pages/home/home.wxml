<view class="page-shell home-page {{currentMode === 'special' ? 'mode-special' : 'mode-general'}}">
  <view class="top-banner card">
    <view class="mode-mini-row">
      <view class="mode-mini-left">
        <text class="mode-dot {{currentMode === 'special' ? 'dot-special' : 'dot-general'}}"></text>
        <text class="mode-mini-text">{{currentMode === 'special' ? '当前：专题版' : '当前：通用版'}} · {{topicTitle || '校园奇遇导览中'}}</text>
      </view>
      <text class="mode-mini-switch" bindtap="onToggleMode">{{currentMode === 'special' ? '切到通用版' : '切到专题版'}}</text>
    </view>

    <view class="banner-main">
      <view class="banner-copy">
        <!-- 微仔陪伴式导览：顶部文案只做轻提醒，不抢地图主舞台 -->
        <text class="banner-title">{{appConfig.appName}}</text>
        <text class="banner-subtitle">今天和微仔一起去校园里逛逛吧</text>
        <text class="banner-tip">今天想从哪边开始逛？点一点地图，看看哪儿有新鲜事。</text>
      </view>

      <view class="banner-mascot">
        <!-- 微仔首页 Banner 素材位：建议替换为 miniprogram/assets/images/ 下的微仔半身或头像图 -->
        <image
          wx:if="{{showMascotImage}}"
          class="mascot-img"
          src="{{appConfig.mascotImage}}"
          mode="aspectFill"
          binderror="onMascotImageError"
        />
        <view wx:else class="mascot-fallback">
          <text class="fallback-title">微仔</text>
          <text class="fallback-sub">素材位</text>
        </view>
      </view>
    </view>
    <view class="banner-blob"></view>
  </view>

  <view class="map-stage card">
    <view class="stage-head">
      <view class="stage-title-wrap">
        <text class="stage-title">校园奇遇导览图</text>
        <text class="stage-subtitle">{{mapHint}}</text>
      </view>
      <button class="light-location-btn {{isCurrentLocationLit ? 'is-lit' : ''}}" bindtap="onLightLocation">
        {{isCurrentLocationLit ? '已点亮这里' : '点亮这里'}}
      </button>
    </view>

    <scroll-view class="area-scroll" scroll-x enable-flex show-scrollbar="false">
      <view class="area-row">
        <view
          wx:for="{{areas}}"
          wx:key="id"
          class="area-chip {{selectedAreaId === item.id ? 'active' : ''}}"
          data-area-id="{{item.id}}"
          bindtap="onAreaTap"
        >
          <text class="area-name">{{item.name}}</text>
          <text class="area-desc">{{selectedAreaId === item.id ? '正在逛这里' : '切换区域'}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 地图主导：将导览图放在首页最核心区域，先逛地图再看活动 -->
    <view class="map-board">
      <view class="map-cloud cloud-a"></view>
      <view class="map-cloud cloud-b"></view>
      <view class="map-path path-a"></view>
      <view class="map-path path-b"></view>

      <view class="zone zone-center {{selectedAreaId === 'center' ? 'active' : ''}}">中间</view>
      <view class="zone zone-west {{selectedAreaId === 'west' ? 'active' : ''}}">西边</view>
      <view class="zone zone-east {{selectedAreaId === 'east' ? 'active' : ''}}">东边</view>

      <view
        wx:for="{{mapLocations}}"
        wx:key="id"
        class="map-point {{item.isInArea ? '' : 'dim'}} {{item.isActive ? 'active' : ''}} {{item.isLit ? 'lit' : ''}}"
        style="left: {{item.x}}%; top: {{item.y}}%;"
        data-location-id="{{item.id}}"
        bindtap="onLocationTap"
      >
        <text class="point-core"></text>
        <text class="point-text">{{item.name}}</text>
        <text wx:if="{{item.isLit}}" class="point-lit">亮</text>
      </view>

      <view class="map-sign">跟着微仔的小路走</view>
    </view>

    <scroll-view class="location-scroll" scroll-x enable-flex show-scrollbar="false">
      <view class="location-row">
        <view
          wx:for="{{locationTabs}}"
          wx:key="id"
          class="location-chip {{item.isActive ? 'active' : ''}} {{item.isLit ? 'lit' : ''}}"
          data-location-id="{{item.id}}"
          bindtap="onLocationTap"
        >
          <text class="location-name">{{item.name}}</text>
          <text class="location-meta">{{item.isLit ? '已点亮' : item.shortDesc}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="spotlight card">
    <view class="spotlight-head">
      <view class="spotlight-copy">
        <text class="spotlight-title">{{currentLocation ? currentLocation.name : '当前点位'}}奇遇</text>
        <text class="spotlight-subtitle">{{spotlightHint}}</text>
      </view>
      <text class="spotlight-count">{{locationEventCount}} 个</text>
    </view>

    <view wx:if="{{recommendedEvents.length === 0}}" class="mini-empty">
      <text class="mini-empty-title">这里暂时没有新活动</text>
      <text class="mini-empty-sub">去别处看看新的奇遇吧</text>
    </view>

    <view
      wx:for="{{recommendedEvents}}"
      wx:key="id"
      class="mini-event-card tone-{{item.cardTone}}"
      data-event-id="{{item.id}}"
      bindtap="onOpenDetail"
    >
      <view class="mini-top">
        <text class="mini-title">{{item.title}}</text>
        <text class="mini-club">{{item.club}}</text>
      </view>
      <text class="mini-time">{{item.time}}</text>
      <text class="mini-highlight line-clamp-2">{{item.spotLine}}</text>
      <button class="mini-open-btn" data-event-id="{{item.id}}" catchtap="onOpenDetail">去看看</button>
    </view>
  </view>

  <view class="discover-entry card" bindtap="onGoDiscover">
    <view class="discover-copy">
      <text class="discover-title">去奇遇页看看全部活动</text>
      <text class="discover-sub">继续逛逛，发现更多社团新鲜事</text>
    </view>
    <text class="discover-arrow">&gt;</text>
  </view>
</view>
