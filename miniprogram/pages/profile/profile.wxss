.profile-page {
  background:
    radial-gradient(circle at 92% 8%, rgba(191, 234, 124, 0.28), transparent 30%),
    radial-gradient(circle at 6% 30%, rgba(246, 167, 200, 0.22), transparent 28%),
    linear-gradient(180deg, #FFFBEF 0%, #F5F2E8 100%);
}

.hero {
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.title-badge {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #DDF3B2;
  color: #5f4a33;
  font-size: 22rpx;
  font-weight: 700;
}

.mode-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.mode-pill {
  font-size: 20rpx;
  color: #6B563C;
  background: #FFF3D6;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.mode-switch {
  margin: 0;
  min-height: auto;
  line-height: 1.3;
  border: none;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 20rpx;
  color: #6B563C;
  background: #D6EEFC;
}

.mode-switch::after {
  border: none;
}

.hero-mascot {
  width: 150rpx;
  height: 150rpx;
  flex-shrink: 0;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #D6EEFC 0%, #F3D3E3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-image {
  width: 142rpx;
  height: 142rpx;
  border-radius: 22rpx;
}

.hero-fallback {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(255, 251, 239, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6B563C;
  font-weight: 700;
}

.stats-row {
  margin-top: 16rpx;
  display: flex;
  gap: 14rpx;
}

.stat {
  flex: 1;
  padding: 18rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #5f4a33;
}

.stat-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8C7B68;
}

.block {
  margin-top: 16rpx;
  padding: 20rpx;
}

.block-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: baseline;
}

.block-title {
  font-size: 30rpx;
  color: #5f4a33;
  font-weight: 700;
}

.block-sub {
  font-size: 20rpx;
  color: #8C7B68;
}

.mini-empty {
  margin-top: 16rpx;
  border-radius: 18rpx;
  padding: 16rpx;
  color: #8C7B68;
  background: #f5f8ea;
  font-size: 24rpx;
}

.mini-btn {
  margin-top: 10rpx;
  width: 260rpx;
}

.line-item,
.fav-item {
  margin-top: 14rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #FFFCF4;
}

.line-main {
  display: block;
  font-size: 28rpx;
  color: #5f4a33;
  font-weight: 700;
}

.line-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8C7B68;
}

.clear-btn {
  margin-top: 24rpx;
  width: 100%;
  border: none;
  border-radius: 999rpx;
  color: #765c3e;
  background: linear-gradient(180deg, #FFE8B8 0%, #F7D85E 100%);
  box-shadow: 0 12rpx 24rpx rgba(247, 216, 94, 0.3);
}

.clear-btn::after {
  border: none;
}
